//@version=6
indicator("BPA: Fade Consecutive Sell Climaxes", overlay=true, max_labels_count=500)

// ── Inputs ──
climaxLookback = input.int(10, "Climax Lookback Bars", minval=5, maxval=20)
climaxMultiple = input.float(1.5, "Climax Size (x avg range)", minval=1.0, maxval=3.0, step=0.1)
minClimaxes    = input.int(3, "Min Consecutive Climaxes", minval=2, maxval=5)
alertOn        = input.bool(true, "Enable Alerts")

// ── Average Range ──
avgRange = ta.sma(high - low, 20)

// ── Count bear climax bars in lookback window ──
isBearClimax(idx) =>
    c = close[idx]
    o = open[idx]
    h = high[idx]
    l = low[idx]
    rng = h - l
    body = math.abs(c - o)
    isBear = c < o
    bigBar = rng > avgRange * climaxMultiple
    isBear and bigBar

bearClimaxCount = 0
for i = 1 to climaxLookback
    if isBearClimax(i)
        bearClimaxCount += 1

// ── Reversal Signal: current bar closes bullish above midpoint ──
midpoint    = (high + low) / 2.0
isBullClose = close > open and close > midpoint

// ── Fire ──
fired = bearClimaxCount >= minClimaxes and isBullClose

// Prevent re-firing on consecutive bars
var int lastFiredBar = 0
fireOnce = fired and (bar_index - lastFiredBar) > 3
if fireOnce
    lastFiredBar := bar_index

// ── Candle Coloring ──
barcolor(fireOnce ? color.new(#39ff14, 0) : na)

// ── Labels ──
if fireOnce
    label.new(bar_index, low, "SELL CLX\nFADE", style=label.style_label_up, color=color.new(#39ff14, 75), textcolor=#39ff14, size=size.small)

// ── Alerts ──
alertcondition(fireOnce, "Fade Sell Climaxes", "Fade Consecutive Sell Climaxes — bullish reversal after 3+ parabolic bear bars")
