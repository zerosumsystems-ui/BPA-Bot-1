// All 13 Profitable Setups — Entries, Stops, Targets & Order Types

//@version=6
indicator("BPA: All Profitable Setups", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════

// ── Setup Toggles ──
grpA = "Tier A — Best (1:1 R:R)"
showLLDB     = input.bool(true, "Fade Lower Low Double Bottom — SHORT",  group=grpA)
showHHDT     = input.bool(true, "Fade Higher High Double Top — LONG",    group=grpA)
showSellClx  = input.bool(true, "Fade Consecutive Sell Climaxes — LONG", group=grpA)
showBuyClx   = input.bool(true, "Fade Consecutive Buy Climaxes — SHORT", group=grpA)
showBOPB     = input.bool(true, "Breakout Pullback — LONG",              group=grpA)
showStairs   = input.bool(true, "Bear Stairs Reversal — LONG",           group=grpA)

grpB = "Tier B — Standard"
showDT       = input.bool(true, "Double Top — SHORT (1:1)",               group=grpB)
showDB       = input.bool(true, "Double Bottom — LONG (0.75:1)",          group=grpB)
showLHDT     = input.bool(true, "Lower High Double Top — SHORT (1:1)",    group=grpB)
showMMClx    = input.bool(true, "Exhaustive Climax at MM — SHORT (0.75:1)", group=grpB)

grpC = "Tier C — Scalps (0.5:1)"
showHLDB     = input.bool(true, "Higher Low Double Bottom — LONG (1:1)",  group=grpC)
showWB       = input.bool(true, "Wedge Bottom — LONG (0.5:1)",            group=grpC)
showWT       = input.bool(true, "Wedge Top — SHORT (0.5:1)",              group=grpC)

// ── Detection Parameters ──
grpP = "Detection"
swingLB      = input.int(3,    "Swing Lookback",              minval=2, maxval=10, group=grpP)
tolerance    = input.float(0.3,"DB/DT Price Tolerance %",     minval=0.05, maxval=2.0, step=0.05, group=grpP)
clxLB        = input.int(10,   "Climax Lookback Bars",        minval=5, maxval=20, group=grpP)
clxMult      = input.float(1.5,"Climax Size (x avg range)",   minval=1.0, maxval=3.0, step=0.1, group=grpP)
minClx       = input.int(3,    "Min Climax Bars",             minval=2, maxval=5, group=grpP)
baseLB       = input.int(8,    "BOPB Base Lookback",          minval=5, maxval=15, group=grpP)
baseOff      = input.int(3,    "BOPB Base Offset",            minval=2, maxval=5, group=grpP)
pbTol        = input.float(0.2,"BOPB Pullback Tolerance %",   minval=0.05, maxval=1.0, step=0.05, group=grpP)
stairLB      = input.int(15,   "Stairs Lookback",             minval=10, maxval=25, group=grpP)
minPush      = input.int(3,    "Stairs Min Pushes",           minval=2, maxval=5, group=grpP)
bodyThr      = input.float(0.5,"Stairs Min Body/Range Ratio", minval=0.3, maxval=0.8, step=0.05, group=grpP)
trendWin     = input.int(20,   "MM Trend Window",             minval=15, maxval=40, group=grpP)
spkBars      = input.int(5,    "MM Spike Bars",               minval=3, maxval=10, group=grpP)
exhMult      = input.float(2.5,"MM Exhaustion Size (x avg)",  minval=1.5, maxval=4.0, step=0.25, group=grpP)

// ── Visual ──
grpV = "Visual"
lineLen      = input.int(10,   "Level Line Length (bars)",    minval=3, maxval=30, group=grpV)
showEMA      = input.bool(true,"Show 20 EMA",                group=grpV)
showLegend   = input.bool(true,"Show Legend Table",           group=grpV)

// ══════════════════════════════════════════════════════════════
// CORE
// ══════════════════════════════════════════════════════════════
ema20    = ta.ema(close, 20)
avgRange = ta.sma(high - low, 20)
tick     = syminfo.mintick
fmt      = format.mintick

plot(showEMA ? ema20 : na, "EMA 20", color=color.new(#f59e0b, 30), linewidth=2)

var color ENTRY_COL  = #00e5ff   // cyan — entry level
var color STOP_COL   = #ff2e63   // red  — stop loss
var color TARGET_COL = #39ff14   // green — profit target
var color LONG_COL   = #39ff14   // green labels for longs
var color SHORT_COL  = #ff2e63   // red labels for shorts

// ══════════════════════════════════════════════════════════════
// LEGEND TABLE
// ══════════════════════════════════════════════════════════════
if barstate.islast and showLegend
    var tbl = table.new(position.top_right, 2, 6, frame_color=color.new(color.white, 70), frame_width=1, border_color=color.new(color.white, 85), border_width=1)
    table.cell(tbl, 0, 0, "BPA Setups", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 60), text_halign=text.align_left)
    table.cell(tbl, 1, 0, "All Stop Orders", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 60), text_halign=text.align_left)
    table.cell(tbl, 0, 1, "——— Cyan", text_color=ENTRY_COL, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 1, "Entry Price", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)
    table.cell(tbl, 0, 2, "- - - Red", text_color=STOP_COL, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 2, "Stop Loss", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)
    table.cell(tbl, 0, 3, "- - - Green", text_color=TARGET_COL, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 3, "Profit Target", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)
    table.cell(tbl, 0, 4, "Red Box", text_color=STOP_COL, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 4, "Risk Zone", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)
    table.cell(tbl, 0, 5, "Green Box", text_color=TARGET_COL, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 5, "Reward Zone", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.black, 40), text_halign=text.align_left)

// ══════════════════════════════════════════════════════════════
// HELPER — draw entry / stop / target with full detail
//
// Every profitable setup in the BPA system uses STOP orders:
//   LONG  = "Buy Stop"  → order sits above market, fills when price rises to it
//   SHORT = "Sell Stop"  → order sits below market, fills when price drops to it
//
// Entry: 1 tick beyond the signal bar (high+tick for longs, low-tick for shorts)
// Stop:  opposite side of the signal bar
// Target: entry + (R:R * risk) in trade direction
// ══════════════════════════════════════════════════════════════
drawSetup(int idx, bool isLong, float entryP, float stopP, float rr, string name, string tip) =>
    risk = math.abs(entryP - stopP)
    if risk > 0
        targetP = isLong ? entryP + rr * risk : entryP - rr * risk
        ord     = isLong ? "Buy Stop" : "Sell Stop"

        // ── Lines: Entry / Stop / Target ──
        line.new(idx, entryP,  idx + lineLen, entryP,  color=ENTRY_COL,  width=2)
        line.new(idx, stopP,   idx + lineLen, stopP,   color=STOP_COL,   width=1, style=line.style_dashed)
        line.new(idx, targetP, idx + lineLen, targetP, color=TARGET_COL, width=1, style=line.style_dashed)

        // ── Shaded zones ──
        box.new(idx, math.max(entryP, stopP), idx + lineLen, math.min(entryP, stopP), bgcolor=color.new(STOP_COL, 92), border_color=na)
        box.new(idx, math.max(entryP, targetP), idx + lineLen, math.min(entryP, targetP), bgcolor=color.new(TARGET_COL, 92), border_color=na)

        // ── Main label: Name + Direction + Order Type + Prices + R:R ──
        ep  = str.tostring(entryP, fmt)
        sp  = str.tostring(stopP, fmt)
        tp  = str.tostring(targetP, fmt)
        rrs = str.tostring(rr) + ":1"
        lbl = name + "\n" + (isLong ? "LONG" : "SHORT") + " — " + ord + " @ " + ep + "\nStop " + sp + " | Target " + tp + " | " + rrs

        col      = isLong ? LONG_COL : SHORT_COL
        lblStyle = isLong ? label.style_label_up : label.style_label_down
        lblY     = isLong ? stopP : stopP
        label.new(idx, lblY, lbl, style=lblStyle, color=color.new(col, 75), textcolor=col, size=size.small, tooltip=tip)
    true

// ══════════════════════════════════════════════════════════════
// SWING DETECTION
// ══════════════════════════════════════════════════════════════

// ── Swing Lows ──
isSwingLow = true
for j = 1 to swingLB
    if not (low[swingLB] <= low[swingLB - j] and low[swingLB] <= low[swingLB + j])
        isSwingLow := false
        break

// ── Swing Highs ──
isSwingHigh = true
for j = 1 to swingLB
    if not (high[swingLB] >= high[swingLB - j] and high[swingLB] >= high[swingLB + j])
        isSwingHigh := false
        break

// ══════════════════════════════════════════════════════════════
// 1–3. DOUBLE BOTTOM FAMILY
//
// Detection: Two swing lows at similar price level (within tolerance %).
// Signal bar: The bar at the second swing low.
// Variants:
//   Plain DB   → 2nd low ≈ 1st low → buyers held → LONG via Buy Stop
//   Higher Low → 2nd low > 1st low → buyers stronger → LONG via Buy Stop
//   Lower Low  → 2nd low < 1st low → sellers winning → SHORT via Sell Stop (fade)
// ══════════════════════════════════════════════════════════════
var float dbLo1 = na
var float dbLo2 = na
if isSwingLow
    dbLo1 := dbLo2
    dbLo2 := low[swingLB]

dbSpread  = math.abs(nz(dbLo1) - nz(dbLo2))
dbAvg     = (nz(dbLo1) + nz(dbLo2)) / 2.0
isDB      = not na(dbLo1) and not na(dbLo2) and dbAvg > 0 and (dbSpread / dbAvg * 100) < tolerance
dbExact   = isDB and math.abs(dbLo2 - dbLo1) < tick * 2
dbHL      = isDB and dbLo2 > dbLo1 and not dbExact
dbLL      = isDB and dbLo2 < dbLo1 and not dbExact
dbPlain   = isDB and not dbHL and not dbLL
dbFired   = isSwingLow and isDB
dbIdx     = bar_index - swingLB
dbHi      = high[swingLB]
dbLo      = low[swingLB]

// Double Bottom → LONG, 0.75:1 R:R
if dbFired and dbPlain and showDB
    drawSetup(dbIdx, true, dbHi + tick, dbLo - tick, 0.75, "DOUBLE BOTTOM", "Two equal swing lows held support. Buyers defended the level.\nBuy Stop 1 tick above signal bar high. Stop below signal bar low.\n0.75:1 R:R — Tier B")

// Higher Low Double Bottom → LONG, 1.0:1 R:R
if dbFired and dbHL and showHLDB
    drawSetup(dbIdx, true, dbHi + tick, dbLo - tick, 1.0, "HIGHER LOW DB", "Second swing low is HIGHER than the first. Buyers getting stronger.\nBuy Stop 1 tick above signal bar high. Stop below signal bar low.\n1:1 R:R — Tier C")

// Fade Lower Low Double Bottom → SHORT, 1.0:1 R:R
if dbFired and dbLL and showLLDB
    drawSetup(dbIdx, false, dbLo - tick, dbHi + tick, 1.0, "FADE LL DOUBLE BOTTOM", "Second swing low BROKE LOWER — sellers winning despite DB appearance.\nSell Stop 1 tick below signal bar low. Stop above signal bar high.\n1:1 R:R — Tier A")

// ══════════════════════════════════════════════════════════════
// 4–6. DOUBLE TOP FAMILY
//
// Detection: Two swing highs at similar price level (within tolerance %).
// Signal bar: The bar at the second swing high.
// Variants:
//   Plain DT    → 2nd high ≈ 1st high → sellers held → SHORT via Sell Stop
//   Lower High  → 2nd high < 1st high → sellers stronger → SHORT via Sell Stop
//   Higher High → 2nd high > 1st high → buyers winning → LONG via Buy Stop (fade)
// ══════════════════════════════════════════════════════════════
var float dtHi1 = na
var float dtHi2 = na
if isSwingHigh
    dtHi1 := dtHi2
    dtHi2 := high[swingLB]

dtSpread  = math.abs(nz(dtHi1) - nz(dtHi2))
dtAvg     = (nz(dtHi1) + nz(dtHi2)) / 2.0
isDT      = not na(dtHi1) and not na(dtHi2) and dtAvg > 0 and (dtSpread / dtAvg * 100) < tolerance
dtExact   = isDT and math.abs(dtHi2 - dtHi1) < tick * 2
dtLH      = isDT and dtHi2 < dtHi1 and not dtExact
dtHH      = isDT and dtHi2 > dtHi1 and not dtExact
dtPlain   = isDT and not dtLH and not dtHH
dtFired   = isSwingHigh and isDT
dtIdx     = bar_index - swingLB
dtHi      = high[swingLB]
dtLo      = low[swingLB]

// Double Top → SHORT, 1.0:1 R:R
if dtFired and dtPlain and showDT
    drawSetup(dtIdx, false, dtLo - tick, dtHi + tick, 1.0, "DOUBLE TOP", "Two equal swing highs held resistance. Sellers defended the level.\nSell Stop 1 tick below signal bar low. Stop above signal bar high.\n1:1 R:R — Tier B")

// Lower High Double Top → SHORT, 1.0:1 R:R
if dtFired and dtLH and showLHDT
    drawSetup(dtIdx, false, dtLo - tick, dtHi + tick, 1.0, "LOWER HIGH DT", "Second swing high is LOWER than the first. Sellers getting stronger.\nSell Stop 1 tick below signal bar low. Stop above signal bar high.\n1:1 R:R — Tier B")

// Fade Higher High Double Top → LONG, 1.0:1 R:R
if dtFired and dtHH and showHHDT
    drawSetup(dtIdx, true, dtHi + tick, dtLo - tick, 1.0, "FADE HH DOUBLE TOP", "Second swing high BROKE HIGHER — buyers winning despite DT appearance.\nBuy Stop 1 tick above signal bar high. Stop below signal bar low.\n1:1 R:R — Tier A")

// ══════════════════════════════════════════════════════════════
// 7. WEDGE BOTTOM (3-Push Reversal)
//
// Detection: 3 consecutive LOWER swing lows (sw3 < sw2 < sw1).
// Each push down is weaker — selling exhaustion.
// Signal bar: The bar at the 3rd push (lowest swing low).
// Entry: Buy Stop above signal bar high.
// ══════════════════════════════════════════════════════════════
var float wb1 = na
var float wb2 = na
var float wb3 = na
if isSwingLow
    wb1 := wb2
    wb2 := wb3
    wb3 := low[swingLB]

wbFired = isSwingLow and not na(wb1) and not na(wb2) and not na(wb3) and wb3 < wb2 and wb2 < wb1

if wbFired and showWB
    drawSetup(dbIdx, true, dbHi + tick, dbLo - tick, 0.5, "WEDGE BOTTOM", "3 consecutive lower swing lows — selling exhaustion after 3 pushes down.\nBuy Stop 1 tick above 3rd push signal bar. Stop below signal bar low.\n0.5:1 R:R (scalp) — Tier C")

// ══════════════════════════════════════════════════════════════
// 8. WEDGE TOP (3-Push Reversal)
//
// Detection: 3 consecutive HIGHER swing highs (sw3 > sw2 > sw1).
// Each push up is weaker — buying exhaustion.
// Signal bar: The bar at the 3rd push (highest swing high).
// Entry: Sell Stop below signal bar low.
// ══════════════════════════════════════════════════════════════
var float wt1 = na
var float wt2 = na
var float wt3 = na
if isSwingHigh
    wt1 := wt2
    wt2 := wt3
    wt3 := high[swingLB]

wtFired = isSwingHigh and not na(wt1) and not na(wt2) and not na(wt3) and wt3 > wt2 and wt2 > wt1

if wtFired and showWT
    drawSetup(dtIdx, false, dtLo - tick, dtHi + tick, 0.5, "WEDGE TOP", "3 consecutive higher swing highs — buying exhaustion after 3 pushes up.\nSell Stop 1 tick below 3rd push signal bar. Stop above signal bar high.\n0.5:1 R:R (scalp) — Tier C")

// ══════════════════════════════════════════════════════════════
// 9. FADE CONSECUTIVE SELL CLIMAXES
//
// Detection: 3+ massive bear bars (> 1.5x avg range) in last 10 bars.
// Parabolic selling is exhausted. Current bar closes bullish above midpoint.
// Signal bar: The bull reversal bar after the climax sequence.
// Entry: Buy Stop above reversal bar high.
// ══════════════════════════════════════════════════════════════
isBearClx(idx) =>
    rng = high[idx] - low[idx]
    close[idx] < open[idx] and rng > avgRange * clxMult

bearClxN = 0
for i = 1 to clxLB
    if isBearClx(i)
        bearClxN += 1

scMid       = (high + low) / 2.0
scBullClose = close > open and close > scMid
scFired     = bearClxN >= minClx and scBullClose

var int scLast = 0
scOnce = scFired and (bar_index - scLast) > 3
if scOnce
    scLast := bar_index

if scOnce and showSellClx
    drawSetup(bar_index, true, high + tick, low - tick, 1.0, "FADE SELL CLIMAXES", str.tostring(bearClxN) + " parabolic bear bars exhausted sellers — reversal expected.\nBuy Stop 1 tick above bull reversal bar. Stop below reversal bar low.\n1:1 R:R — Tier A")

// ══════════════════════════════════════════════════════════════
// 10. FADE CONSECUTIVE BUY CLIMAXES
//
// Detection: 3+ massive bull bars (> 1.5x avg range) in last 10 bars.
// Parabolic buying is exhausted. Current bar closes bearish below midpoint.
// Signal bar: The bear reversal bar after the climax sequence.
// Entry: Sell Stop below reversal bar low.
// ══════════════════════════════════════════════════════════════
isBullClx(idx) =>
    rng = high[idx] - low[idx]
    close[idx] > open[idx] and rng > avgRange * clxMult

bullClxN = 0
for i = 1 to clxLB
    if isBullClx(i)
        bullClxN += 1

bcMid       = (high + low) / 2.0
bcBearClose = close < open and close < bcMid
bcFired     = bullClxN >= minClx and bcBearClose

var int bcLast = 0
bcOnce = bcFired and (bar_index - bcLast) > 3
if bcOnce
    bcLast := bar_index

if bcOnce and showBuyClx
    drawSetup(bar_index, false, low - tick, high + tick, 1.0, "FADE BUY CLIMAXES", str.tostring(bullClxN) + " parabolic bull bars exhausted buyers — reversal expected.\nSell Stop 1 tick below bear reversal bar. Stop above reversal bar high.\n1:1 R:R — Tier A")

// ══════════════════════════════════════════════════════════════
// 11. BREAKOUT PULLBACK
//
// Detection: Strong bull breakout 2 bars ago broke above consolidation base.
// Current bar pulls back to test the old base top as support.
// Bar closes in upper half = buyers defending the breakout level.
// Signal bar: The current pullback test bar.
// Entry: Buy Stop above test bar high.
// ══════════════════════════════════════════════════════════════
bpTop   = ta.highest(high, baseLB - baseOff)[baseOff]
bpBot   = ta.lowest(low, baseLB - baseOff)[baseOff]
bpRange = bpTop - bpBot
bpBO    = close[2] > bpTop and (high[2] - low[2]) > bpRange * 0.5
bpTest  = low <= bpTop and low >= bpTop * (1 - pbTol / 100)
bpMid   = (high + low) / 2.0
bpGood  = close > bpMid
bpFired = bpBO and bpTest and bpGood

var int bpLast = 0
bpOnce = bpFired and (bar_index - bpLast) > 5
if bpOnce
    bpLast := bar_index

if bpOnce and showBOPB
    drawSetup(bar_index, true, high + tick, low - tick, 1.0, "BREAKOUT PULLBACK", "Strong breakout retesting old resistance as new support.\nBuyers defended the breakout level (bar closed in upper half).\nBuy Stop 1 tick above test bar. Stop below test bar low.\n1:1 R:R — Tier A")

// ══════════════════════════════════════════════════════════════
// 12. BEAR STAIRS REVERSAL (3rd/4th Push)
//
// Detection: 3+ descending swing lows (staircase pattern) in lookback.
// Sellers exhausted after multiple pushes down.
// Current bar: Strong bull reversal bar (closes bullish, body > 50% of range).
// Signal bar: The bull reversal bar.
// Entry: Buy Stop above reversal bar high.
// ══════════════════════════════════════════════════════════════
stMinima = 0
for j = 2 to stairLB - 2
    if low[j] < low[j - 1] and low[j] < low[j - 2] and low[j] < low[j + 1] and low[j] < low[j + 2]
        stMinima += 1

stMid    = (high + low) / 2.0
stBody   = math.abs(close - open)
stRng    = high - low
stBull   = close > open and close > stMid
stStrong = stRng > 0 ? (stBody / stRng) > bodyThr : false
stFired  = stMinima >= minPush and stBull and stStrong

var int stLast = 0
stOnce = stFired and (bar_index - stLast) > 5
if stOnce
    stLast := bar_index

if stOnce and showStairs
    drawSetup(bar_index, true, high + tick, low - tick, 1.0, "BEAR STAIRS REVERSAL", str.tostring(stMinima) + " descending pushes exhausted — strong bull reversal bar.\nBuy Stop 1 tick above reversal bar. Stop below reversal bar low.\n1:1 R:R — Tier A")

// ══════════════════════════════════════════════════════════════
// 13. EXHAUSTIVE BULL CLIMAX AT MEASURED MOVE
//
// Detection: Initial spike establishes a size. Price hits measured move target
// (spike doubled from its high) with a massive exhaustion bar (> 2.5x avg)
// that closes in the lower half = reversal.
// Signal bar: The exhaustion climax bar at the measured move target.
// Entry: Sell Stop below climax bar low.
// ══════════════════════════════════════════════════════════════
mmSpkLo  = ta.lowest(low, spkBars)[trendWin - spkBars]
mmSpkHi  = ta.highest(high, spkBars)[trendWin - spkBars]
mmSpkSz  = mmSpkHi - mmSpkLo
mmTarget = mmSpkHi + mmSpkSz
mmChAvg  = ta.sma(high - low, trendWin - spkBars)

mmHit    = high >= mmTarget
mmBig    = (high - low) > mmChAvg * exhMult
mmRevBar = close < (high + low) / 2.0
mmFired  = close > ema20 and mmHit and mmBig and mmRevBar and mmSpkSz > 0

var int mmLast = 0
mmOnce = mmFired and (bar_index - mmLast) > 10
if mmOnce
    mmLast := bar_index

if mmOnce and showMMClx
    drawSetup(bar_index, false, low - tick, high + tick, 0.75, "EXHAUSTIVE CLIMAX AT MM", "Hit measured move target with massive exhaustion bar closing weak.\nSell Stop 1 tick below climax bar. Stop above climax bar high.\n0.75:1 R:R — Tier B")

// MM target reference line
plot(showMMClx and mmSpkSz > 0 and close > ema20 ? mmTarget : na, "MM Target", color=color.new(#f59e0b, 60), linewidth=1, style=plot.style_cross)

// ══════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════
anyLong  = (dbFired and dbPlain and showDB) or (dbFired and dbHL and showHLDB) or (dtFired and dtHH and showHHDT) or (wbFired and showWB) or (scOnce and showSellClx) or (bpOnce and showBOPB) or (stOnce and showStairs)
anyShort = (dbFired and dbLL and showLLDB) or (dtFired and dtPlain and showDT) or (dtFired and dtLH and showLHDT) or (wtFired and showWT) or (bcOnce and showBuyClx) or (mmOnce and showMMClx)

alertcondition(anyLong,  "BPA Long Signal",  "BPA profitable LONG setup detected")
alertcondition(anyShort, "BPA Short Signal", "BPA profitable SHORT setup detected")
alertcondition(anyLong or anyShort, "BPA Any Signal", "BPA profitable setup detected")
